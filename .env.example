# Environment variables template for Universal Agents v2
# Copy to .env and fill in your values

# OpenRouter API key (required for OpenRouter agents)
OPENROUTER_API_KEY=

# Browser agent storage state paths (JSON files from Playwright)
# Run `python -m universal_agents.browser.save_login <provider>` to generate
CLAUDE_STORAGE_STATE=
GEMINI_STORAGE_STATE=
GPT_STORAGE_STATE=
PPLX_STORAGE_STATE=
